# Copy this file to local.env and fill in your values.
# local.env is gitignored and never committed.

# Path to your primary project repo on this machine.
# Used by skills as {{PROJECT_REPO}} (e.g. in jira-ticket, pre-commit-review).
# Example:
# PROJECT_REPO="$HOME/my-project"

# Jira project key — the prefix before the ticket number.
# e.g. if your tickets are PROJ-1234, the key is PROJ.
# Used in JQL queries and ticket display by new-jira-ticket, jira-ticket.
# JIRA_PROJECT_KEY=PROJ

# Jira instance base URL — your Atlassian domain.
# e.g. https://yourcompany.atlassian.net
# Used to generate ticket links: {{JIRA_BASE_URL}}/browse/PROJ-1234
# JIRA_BASE_URL=https://yourcompany.atlassian.net

# Your Jira account email — used to look up your account ID when assigning tickets.
# JIRA_ASSIGNEE_EMAIL=your-email@company.com

# Jira cloud workspace ID — used by write-pr, new-release-note for Atlassian MCP cloudId.
# Find it at: Jira Settings → Products → Jira Software → your workspace URL contains the UUID.
# JIRA_WORKSPACE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# GitHub PR reviewers, comma-separated (used by write-pr).
# PR_REVIEWERS=reviewer1,reviewer2,reviewer3

# Jenkins CI job name prefix — the part before the branch suffix.
# e.g. if your jobs are MyCompany-Android-CI-Develop-FeatureName, the prefix is MyCompany-Android-CI-Develop
# JENKINS_JOB_PREFIX=MyCompany-Android-CI-Develop

# Filename of the project-specific conventions agent (must exist in agency-agents
# and be synced to ~/.claude/agents/ by install.sh).
# Used by skills as {{PROJECT_CONVENTIONS_AGENT}}.
# Example:
# PROJECT_CONVENTIONS_AGENT="engineering-my-conventions.md"
